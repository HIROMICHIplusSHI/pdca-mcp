{
  "name": "@proaca-dev/pdca-mcp",
  "version": "0.1.0",
  "description": "PDCA報告アプリ用MCPサーバー (Claude Code / Claude Desktop 向け・非公式開発版)",
  "type": "module",
  "bin": {
    "pdca-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/add-shebang.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http --port 3100",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "pdca",
    "proaca"
  ],
  "author": "HIROMICHIplusSHI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HIROMICHIplusSHI/pdca-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/HIROMICHIplusSHI/pdca-mcp/issues"
  },
  "homepage": "https://github.com/HIROMICHIplusSHI/pdca-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
